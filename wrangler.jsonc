{
  "name": "danggu-ar",
  "compatibility_date": "2026-02-09",
  "main": "src/worker.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "none"
  },
  "r2_buckets": [
    {
      "binding": "AR_BUCKET",
      "bucket_name": "danggu-ar-uploads"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "AR_META",
      "id": "ffa9c74587224e8a8eb366b379f7922f"
    }
  ]
}
